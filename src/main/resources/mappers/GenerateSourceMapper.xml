<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.generate.repository.GenerateSourceRepo">
    <select id="findByGeneratorId" resultType="com.generate.entity.GenerateSource">
        select * from generate_source where generator_id = #{id} order by source_id desc
    </select>

    <select id="findById" resultType="com.generate.entity.GenerateSource">
        select * from generate_source where source_id = #{id}
    </select>
</mapper>